% ==========================================================
% beamercolorthememsu.sty
% Paleta azul institucional del Tecnológico de Monterrey
% (azul tomado del logo oficial, #0658A6) para el tema gemini
% autocontenido de este póster. Sin dependencias.
% ==========================================================

\ProvidesPackage{beamercolorthememsu}

\selectcolormodel{RGB}

\definecolor{tecblue}{RGB}{6,88,166}      % azul Tec (logo) — headline/footer/títulos
\definecolor{tecnavy}{RGB}{3,55,104}      % azul marino (énfasis)
\definecolor{tecaccent}{RGB}{31,111,196}  % azul medio (acentos)
\definecolor{teclight}{RGB}{233,241,250}  % azul muy claro (fondo de bloques)
\definecolor{tectext}{RGB}{33,33,33}      % texto base

\setbeamercolor{headline}{fg=white,bg=tecblue}
\setbeamercolor{headline title}{fg=white,bg=tecblue}
\setbeamercolor{headline author}{fg=white,bg=tecblue}
\setbeamercolor{headline institute}{fg=teclight,bg=tecblue}

\setbeamercolor{block title}{fg=white,bg=tecblue}
\setbeamercolor{block body}{fg=tectext,bg=teclight}

\setbeamercolor{block alerted title}{fg=white,bg=tecnavy}
\setbeamercolor{block alerted body}{fg=tectext,bg=tecaccent!12}

\setbeamercolor{block example title}{fg=white,bg=tecaccent}
\setbeamercolor{block example body}{fg=tectext,bg=tecaccent!8}

\setbeamercolor{footline}{fg=white,bg=tecblue}

\setbeamercolor{itemize item}{fg=tecaccent}
\setbeamercolor{itemize subitem}{fg=tecaccent}
\setbeamercolor{enumerate item}{fg=tecaccent}
\setbeamercolor{caption name}{fg=tecaccent}
