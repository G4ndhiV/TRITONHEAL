import triton
import triton.language as tl

@triton.jit
def elem_14(x_ptr, out_ptr, n, BLOCK_SIZE: tl.constexpr  # BLOCK=48 non-power-of-two):
    pid = tl.program_id(0)
    offs = pid * BLOCK_SIZE + tl.arange(0, 48)
    mask = offs < n
    x = tl.load(x_ptr + offs, mask=mask)
    tl.store(out_ptr + offs, x * 2.0, mask=mask)
