import triton
import triton.language as tl

@triton.jit
def softmax_27(out_ptr, inp_ptr, n, BLOCK_SIZE: tl.constexpr  # BLOCK=48 non-power-of-two):
    pid = tl.program_id(0)
    offs = pid * BLOCK_SIZE + tl.arange(0, 48)
    mask = offs < n
    x = tl.load(inp_ptr + offs, mask=mask)
    x = tl.exp(x - tl.max(x, axis=0))
    tl.store(out_ptr + offs, x / tl.sum(x, axis=0), mask=mask)
